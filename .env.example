DISTRACTED_THRESHOLD=0.35
DISTRACT_DOWN_PITCH_DEG=18.0
DISTRACT_SIDE_YAW_DEG=20.0
PHONE_EYE_DOWN_THRESHOLD=0.56
NEUTRAL_EMA_ALPHA=0.06
NEUTRAL_UPDATE_MAX_YAW=14.0
NEUTRAL_UPDATE_MAX_PITCH=12.0
NEUTRAL_MIN_SAMPLES=25
